# Overleaf git authentication token
OVERLEAF_TOKEN=

# Comma-separated list of Overleaf project IDs
PROJECT_IDS=project_id_1,project_id_2

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to receive review messages
TELEGRAM_CHAT_ID=

# (Optional) Telegram forum topic/thread ID for supergroups with Topics enabled
TELEGRAM_TOPIC_ID=
